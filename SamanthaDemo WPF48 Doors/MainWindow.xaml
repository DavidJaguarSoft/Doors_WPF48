<Window x:Class="SamanthaDemo_WPF48_Doors.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SamanthaDemo_WPF48_Doors"
        mc:Ignorable="d"
        Title="Samantha Demo WPF Framework 4.8 Doors Control" Width="900" Height="700" MinWidth="900" MaxWidth="900" MinHeight="700" MaxHeight="700" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/house sketch 001.jpg" Stretch="Fill" Opacity="0.7"
               HorizontalAlignment="Center" Width="888" Height="664" VerticalAlignment="Top" Margin="0,10,0,0"/>

        <Rectangle Fill ="White"  Margin="695,44,0,0" HorizontalAlignment="Left" Width="183" Height="630" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5"/>

        <TextBlock Text="version: SD_WPF48_DOORS.2026.04.17.02" Margin="608,9,0,0" HorizontalAlignment="Left" TextAlignment="Right" Width="258"
                   Height="16" VerticalAlignment="Top" FontSize="12"/>

        <Button Name="ButtonOpenAll" Content="Open all the doors" Background="Blue"
                Foreground="White" FontSize="11" FontWeight="Normal" VerticalAlignment="Top"
                Click="ButtonOpenAll_Click" Height="20" Margin="32,531,0,0" HorizontalAlignment="Left" Width="100"/>
        <Button Name="ButtonCloseAll" Content="Close all the doors" Background="Red"
                Foreground="White" FontSize="11" FontWeight="Normal" VerticalAlignment="Top"
                Click="ButtonCloseAll_Click" Height="20" Margin="32,559,0,0" HorizontalAlignment="Left" Width="100"/>


        <ProgressBar Name="ProgressBarListening" Value="0" Height="14" Width="196" Background="DarkGray"
                     Foreground="Red" HorizontalAlignment="Left" Margin="496,619,0,0" VerticalAlignment="Top" />
        <TextBlock Name="TextBlockListening" Text="{Binding ElementName=ProgressBarListening, Path=Value, StringFormat={}{0:0}}" FontSize="9" Foreground="White"
                   HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Top" Width="27" Margin="583,619,0,0" />
        <TextBlock Name="TextBlockInstructionDetected" Text="---" FontSize="10" Foreground="Blue"
                   HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Top" Width="196" Margin="496,635,0,0" />

        <TextBlock Margin="946,626,0,0" HorizontalAlignment="Left" Width="220" Height="23" VerticalAlignment="Top">
            <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://www.DavidJaguarSoft.com">
                Administrar mi cuenta de Samantha
            </Hyperlink>
        </TextBlock>

        <Rectangle Fill ="Red"  Margin="34,630,0,0" Height="10" VerticalAlignment="Top" HorizontalAlignment="Left" Width="10" />
        <TextBlock Margin="49,628,0,0" HorizontalAlignment="Left" Width="66" Height="16" VerticalAlignment="Top" FontSize="10"><Run Language="es-mx" Text="Close Door"/></TextBlock>
        <Rectangle Fill ="Blue"  Margin="150,630,0,0" Height="10" VerticalAlignment="Top" HorizontalAlignment="Left" Width="10" />
        <TextBlock Margin="166,628,0,0" HorizontalAlignment="Left" Width="68" Height="16" VerticalAlignment="Top" FontSize="10"><Run Language="es-mx" Text="Open Door"/></TextBlock>

        <TextBlock Margin="132,302,0,0" HorizontalAlignment="Left" Width="48" Height="16" VerticalAlignment="Top"><Run Language="es-mx" Text="Door"/><Run Text=" 1"/></TextBlock>
        <Button Name="ButtonDoorOne" Height="10" Background="Red" Margin="106,285,0,0" VerticalAlignment="Top"
                   HorizontalAlignment="Left" Width="72" Click="ButtonDoor_Click">
            <Button.RenderTransform>
                <RotateTransform x:Name="ButtonDoorOneRotation" Angle="0" />
            </Button.RenderTransform>
        </Button>

        <TextBlock Margin="246,519,0,0" HorizontalAlignment="Left" Width="44" Height="16" VerticalAlignment="Top"><Run Language="es-mx" Text="Door"/><Run Text=" "/><Run Text="2"/></TextBlock>
        <Button Name="ButtonDoorTwo" Background="Red" Margin="294,473,0,0" HorizontalAlignment="Left"
                Width="10" Height="70" VerticalAlignment="Top" Click="ButtonDoor_Click">
            <Button.RenderTransform>
                <RotateTransform x:Name="ButtonDoorTowRotation" Angle="0" />
            </Button.RenderTransform>
        </Button>

        <TextBlock Margin="704,153,0,0" HorizontalAlignment="Left" Width="50" Height="16" VerticalAlignment="Top"><Run Language="es-mx" Text="Door"/><Run Text=" "/><Run Text="3"/></TextBlock>
        <Button Name="ButtonDoorThree" Background="Red" Margin="672,96,0,0" HorizontalAlignment="Left"
                Width="10" Height="151" VerticalAlignment="Top" Click="ButtonDoor_Click">
            <Button.RenderTransform>
                <RotateTransform x:Name="ButtonDoorThreeRotation" Angle="0" />
            </Button.RenderTransform>
        </Button>

        <TextBlock Margin="704,418,0,0" HorizontalAlignment="Left" Width="50" Height="16" VerticalAlignment="Top"><Run Language="es-mx" Text="Door"/><Run Text=" "/><Run Text="4"/></TextBlock>
        <Button Name="ButtonDoorFour" Background="Red" Margin="673,342,0,0" HorizontalAlignment="Left"
                Width="10" Height="153" VerticalAlignment="Top" Click="ButtonDoor_Click">
            <Button.RenderTransform>
                <RotateTransform x:Name="ButtonDoorFourRotation" Angle="0" />
            </Button.RenderTransform>
        </Button>
    </Grid>
</Window>
